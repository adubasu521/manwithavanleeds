---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroHome from '../components/sections/HeroHome.astro';
import ServiceGrid from '../components/sections/ServiceGrid.astro';
import LocationGrid from '../components/sections/LocationGrid.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTASection from '../components/sections/CTASection.astro';
import VanFleet from '../components/sections/VanFleet.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import UspIcon from '../components/UspIcon';
import FilledCheckedIcon from '../components/icons/filled-checked-icon';
import TruckElectricIcon from '../components/icons/truck-electric-icon';
import UsersIcon from '../components/icons/users-icon';
import HandHeartIcon from '../components/icons/hand-heart-icon';
import PhoneVolume from '../components/icons/phone-volume';
import MapPinIcon from '../components/icons/map-pin-icon';
import { siteConfig } from '../data/site';
import { services } from '../data/services';
import { locations } from '../data/locations';
import { affiliateUrl } from '../utils/affiliate';

const topServices = services.slice(0, 6);
const leedsDistricts = locations.filter(l => !['bradford','wakefield','dewsbury','huddersfield','halifax','harrogate','york'].includes(l.slug));
const widerArea = locations.filter(l => ['bradford','wakefield','dewsbury','huddersfield','halifax','harrogate','york'].includes(l.slug));

const testimonials = [
  { quote: "Brilliant service. Two guys turned up on time, worked incredibly hard and didn't stop until everything was done. The price was exactly as quoted — no hidden extras.", author: "James T.", location: "Headingley, Leeds", rating: 5 },
  { quote: "Used them twice now for student moves in Hyde Park. Friendly, fast, and great value compared to other quotes I got. The van was huge — everything fit in one trip.", author: "Sophie M.", location: "Hyde Park, Leeds", rating: 5 },
  { quote: "Moved from Leeds to Bradford in under 3 hours. Communication was excellent from start to finish. Will absolutely use again and have already recommended to friends.", author: "Raj P.", location: "Bradford", rating: 5 },
];
---

<BaseLayout
  title="Man With A Van Leeds | Fixed Prices, 7 Days a Week | 020 3318 4720"
  description="Leeds' most trusted man and van service. Fixed-price quotes for house removals, student moves, furniture delivery and more across Leeds and West Yorkshire. Fully insured, 7 days a week."
  canonical="https://manwithavanleeds.co.uk"
>
  <HeroHome />

  <!-- USP Bar -->
  <section class="bg-white border-b border-neutral-200 py-10">
    <Container>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
        {siteConfig.usps.map((usp) => (
          <div class="flex flex-col items-center text-center gap-2">
            <div class="w-12 h-12 bg-primary-50 rounded-full flex items-center justify-center">
              <UspIcon title={usp.title} className="w-6 h-6 text-primary-600" client:idle />
            </div>
            <span class="text-sm font-semibold text-neutral-800 leading-tight">{usp.title}</span>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Services -->
  <Section>
    <Container>
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-neutral-900 font-heading">Our Services</h2>
        <p class="mt-4 text-lg text-neutral-600 max-w-2xl mx-auto">From local man and van to full house removals — we cover everything across Leeds and West Yorkshire.</p>
      </div>
      <ServiceGrid services={topServices} heading="" />
      <div class="text-center mt-10">
        <a href="/services" class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors">
          View all 12 services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </Container>
  </Section>

  <!-- Van Fleet -->
  <Section class="bg-neutral-50">
    <Container>
      <VanFleet />
    </Container>
  </Section>

  <!-- Stats Bar -->
  <section class="bg-primary-700 py-12">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="flex flex-col items-center gap-2">
          <TruckElectricIcon size={32} color="white" client:idle />
          <div class="text-4xl font-bold text-white font-heading">{siteConfig.stats.movesCompleted}</div>
          <div class="text-primary-200 text-sm font-medium">Moves Completed</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <UsersIcon size={32} color="white" client:idle />
          <div class="text-4xl font-bold text-white font-heading">{siteConfig.stats.reviews}</div>
          <div class="text-primary-200 text-sm font-medium">5-Star Reviews</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <HandHeartIcon size={32} color="white" client:idle />
          <div class="text-4xl font-bold text-white font-heading">{siteConfig.stats.averageRating}/5</div>
          <div class="text-primary-200 text-sm font-medium">Average Rating</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <MapPinIcon size={32} color="white" client:idle />
          <div class="text-4xl font-bold text-white font-heading">{siteConfig.stats.yearsActive} Yrs</div>
          <div class="text-primary-200 text-sm font-medium">Serving Leeds</div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Testimonials -->
  <Section>
    <Container>
      <Testimonials testimonials={testimonials} />
    </Container>
  </Section>

  <!-- Areas -->
  <Section class="bg-neutral-50">
    <Container>
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-neutral-900 font-heading">Areas We Cover</h2>
        <p class="mt-4 text-lg text-neutral-600 max-w-2xl mx-auto">Based in Leeds, we serve the city centre and all surrounding districts, as well as Bradford, Wakefield, Harrogate, York and beyond.</p>
      </div>
      <div class="mb-8">
        <h3 class="text-lg font-semibold text-neutral-700 mb-4">Leeds Districts</h3>
        <LocationGrid locations={leedsDistricts} heading="" />
      </div>
      <div>
        <h3 class="text-lg font-semibold text-neutral-700 mb-4">Wider West Yorkshire & Beyond</h3>
        <LocationGrid locations={widerArea} heading="" />
      </div>
      <div class="text-center mt-10">
        <a href="/locations" class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors">
          View all service areas
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </Container>
  </Section>

  <!-- Why Choose Us -->
  <Section>
    <Container>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-neutral-900 font-heading">Why Leeds Chooses Us</h2>
          <p class="mt-4 text-lg text-neutral-600">We've been moving homes and businesses across Leeds for {siteConfig.stats.yearsActive} years. No call centres, no subcontractors — just our own team and our own vans.</p>
          <ul class="mt-6 space-y-4">
            {siteConfig.usps.map((usp) => (
              <li class="flex gap-3 items-start">
                <div class="text-secondary-500 shrink-0 mt-0.5">
                  <FilledCheckedIcon size={20} color="#F59E0B" client:idle />
                </div>
                <div>
                  <span class="font-semibold text-neutral-800">{usp.title}</span>
                  <span class="text-neutral-600"> — {usp.description}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-primary-50 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-primary-800 font-heading mb-4">Get a Free Quote in Minutes</h3>
          <p class="text-primary-700 mb-6">Tell us where you're moving from and to, and we'll give you a fixed price — no obligation.</p>
          <a href={affiliateUrl()} target="_blank" rel="sponsored" onclick="gtag('event','cta_click',{'button_position':'quote_box','service':'homepage'})" class="block w-full text-center bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
            Request a Free Quote
          </a>
          <div class="mt-4 text-center flex items-center justify-center gap-2">
            <PhoneVolume size={16} color="#1E3A5F" client:idle />
            <span class="text-primary-600 text-sm">or call us now: </span>
            <a href={`tel:${siteConfig.phoneTel}`} class="text-primary-800 font-semibold text-sm hover:underline">{siteConfig.phoneDisplay}</a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
