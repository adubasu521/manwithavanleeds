---
import SEOHead from '../components/seo/SEOHead.astro';
import SchemaOrganization from '../components/seo/SchemaOrganization.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/app.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, ogType, noindex } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <SchemaOrganization />
    <slot name="head" />
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HK9Z2HPGRS"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HK9Z2HPGRS');
    </script>
  </head>
  <body class="min-h-screen flex flex-col" data-city="leeds">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Affiliate subid injection: appends mwv_leeds_{timestamp} on click -->
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var citySlug = document.body.getAttribute('data-city') || 'leeds';
        document.querySelectorAll('a[href*="anyvan.com"]').forEach(function (a) {
          a.addEventListener('click', function () {
            var url = new URL(a.href);
            url.searchParams.set('subid', 'mwv_' + citySlug + '_' + Date.now());
            a.href = url.toString();
          });
        });
      });
    </script>
  </body>
</html>
